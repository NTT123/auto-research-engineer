{
    "env": {
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
        "CLAUDE_CODE_NO_FLICKER": "1",
        "CLAUDE_CODE_TEAM_MODE": "tmux",
        "BASH_DEFAULT_TIMEOUT_MS": "200000",
        "BASH_MAX_TIMEOUT_MS": "600000"
    },
    "theme": "light",
    "model": "opus[1m]",
    "permissions": {
        "allow": ["Bash", "WebFetch"],
        "deny": []
    },
    "sandbox": {
        "enabled": true,
        "network": {
            "allowedDomains": ["*"]
        }
    }
}
